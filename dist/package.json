{
    "name": "@bautran1911/n8n-nodes-zalo-oa",
    "version": "1.0.7",
    "description": "n8n community node tích hợp Zalo Official Account (Zalo OA) – gửi ZBS Template Message qua số điện thoại và tự động quản lý Access Token.",
    "license": "MIT",
    "homepage": "https://github.com/bautran1911/n8n-nodes-zalo-oa#readme",
    "keywords": [
        "n8n-community-node-package",
        "n8n",
        "zalo",
        "zalo-oa",
        "zalo official account",
        "zalo zbs",
        "zalo template message",
        "vietnam",
        "messaging",
        "automation"
    ],
    "author": {
        "name": "Báu đẹp trai",
        "email": "bautran1911@gmail.com",
        "url": "https://github.com/bautran1911"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bautran1911/n8n-nodes-zalo-oa.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/ZaloOaApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/ZaloOa/ZaloOa.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.32.0",
        "prettier": "3.6.2",
        "release-it": "^19.0.4",
        "typescript": "5.9.2"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "publishConfig": {
        "access": "public"
    }
}
